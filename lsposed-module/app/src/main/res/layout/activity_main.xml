<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Logo / Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 GlitchDraft"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0084FF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LSPosed Module"
            android:textSize="14sp"
            android:textColor="#65676B"
            android:layout_marginBottom="24dp" />

        <!-- Status banner -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="13sp"
            android:background="#FFF3E0"
            android:layout_marginBottom="24dp" />

        <!-- Firebase JSON config card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Firebase Configuration"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1C1E21"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paste the same Firebase config JSON object you use in the browser extension popup."
                android:textSize="12sp"
                android:textColor="#65676B"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_firebase_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="{ &quot;apiKey&quot;: &quot;AIza...&quot;, &quot;projectId&quot;: &quot;...&quot; }"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:maxLines="12"
                android:gravity="top|start"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"
                android:background="@android:color/white"
                android:padding="8dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Configuration"
                android:backgroundTint="#0084FF"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- How it works -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How it works"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1C1E21"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Enable this module in LSPosed Manager\n2. Select the target apps in the module scope (Messenger, WhatsApp, Discord, Chrome…)\n3. Paste your Firebase JSON config above and tap Save\n4. Grant the &#34;Display over other apps&#34; permission when prompted\n5. Force-stop the target apps\n6. Open any supported messaging site — the GlitchDraft 📝 floating icon will appear"
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>

