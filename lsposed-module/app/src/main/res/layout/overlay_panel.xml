<?xml version="1.0" encoding="utf-8"?>
<!-- GlitchDraft floating panel — mirrors the .saved-messages-container layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="480dp"
    android:orientation="vertical"
    android:background="@drawable/panel_bg"
    android:elevation="12dp">

    <!-- Header (drag handle) -->
    <LinearLayout
        android:id="@+id/panel_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0084FF"
        android:padding="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📝 GlitchDraft"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="×"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Draft list (scrollable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/draft_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#F0F2F5"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_draft_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type a draft message…"
            android:minLines="2"
            android:maxLines="4"
            android:background="@android:color/white"
            android:padding="8dp"
            android:textSize="13sp"
            android:inputType="textMultiLine|textCapSentences" />

        <TextView
            android:id="@+id/btn_save_draft"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/circle_accent" />

    </LinearLayout>

</LinearLayout>
